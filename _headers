/*
  # ============================================================
  # HTTP Security Headers
  # Applies to: Cloudflare Pages, Netlify, Vercel
  # For GitHub Pages: route traffic through Cloudflare (free)
  #   then add these as Cloudflare Transform Rules
  # ============================================================

  # Force HTTPS for 1 year — only commit once HTTPS confirmed working
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Prevent MIME-type sniffing
  X-Content-Type-Options: nosniff

  # Clickjacking: allow same origin only
  X-Frame-Options: SAMEORIGIN

  # Disable legacy XSS auditor (CSP handles this now)
  X-XSS-Protection: 0

  # Referrer policy
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions policy — disable all features this site does not use
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=(), browsing-topics=()

  # Cross-origin isolation
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin

  # Full CSP as HTTP header (stronger than meta — allows frame-ancestors)
  Content-Security-Policy: default-src 'none'; script-src 'self' 'sha384-mD7chyvs18CA1lC8j5WbGwGxqDpC9ZoRKY2wkfCqMMm4/SwuL/P7Y4JnSqkWD6H' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' https://a.espncdn.com https://espn.com data:; connect-src 'self' https://site.api.espn.com https://sports.core.api.espn.com https://cdn.espn.com https://docs.google.com; object-src 'none'; base-uri 'self'; form-action 'none'; frame-ancestors 'self'; upgrade-insecure-requests;

/styles.css
  Cache-Control: public, max-age=86400, stale-while-revalidate=3600

/script.js
  Cache-Control: public, max-age=3600, stale-while-revalidate=600
